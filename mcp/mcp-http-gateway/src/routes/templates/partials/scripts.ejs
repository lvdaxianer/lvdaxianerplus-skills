  /**
   * 渲染配置说明面板
   *
   * @author lvdaxianerplus
   * @date 2026-04-20
   */
  function renderConfigReference() {
    const container = document.getElementById('config-reference');
    // 条件注释：容器不存在时跳过渲染
    if (!container) {
      return;
    } else {
      container.innerHTML = renderConfigSection(CONFIG_REFERENCE, 'config');
    }
  }

  /**
   * 渲染单个配置区域
   *
   * @param section - 配置区域数据
   * @param path - 配置路径
   * @returns HTML 字符串
   * @author lvdaxianerplus
   * @date 2026-04-20
   */
  function renderConfigSection(section, path) {
    let html = '';
    for (const key in section) {
      const item = section[key];
      const itemPath = path + '.' + key;
      const hasChildren = item.children && Object.keys(item.children).length > 0;
      const isExpanded = configSectionsExpanded[itemPath];
      const icon = hasChildren ? (isExpanded ? '▼' : '▶') : '•';
      const typeColor = item.type === 'string' ? '#3B82F6' :
                        item.type === 'number' ? '#10B981' :
                        item.type === 'boolean' ? '#F59E0B' :
                        item.type === 'array' ? '#8B5CF6' :
                        item.type === 'object' ? '#6B7280' : '#64748B';

      html += '<div style="padding:8px 0;border-bottom:1px solid var(--border);">';
      // 条件注释：有子节点时添加点击展开功能，无子节点时仅显示属性信息
      if (hasChildren) {
        html += '<div style="cursor:pointer;font-weight:500;display:flex;align-items:center;gap:8px;" onclick="toggleConfigSection(\'' + itemPath + '\')">';
        html += '<span style="font-size:12px;color:var(--text-muted);">' + icon + '</span>';
        html += '<span style="color:var(--primary);">' + key + '</span>';
        html += '<span style="font-size:11px;background:' + typeColor + ';color:white;padding:2px 6px;border-radius:4px;">' + item.type + '</span>';
        html += '</div>';
        html += '<div style="font-size:13px;color:var(--text-muted);padding-left:24px;margin-top:4px;">' + item.desc + '</div>';
        // 条件注释：展开时显示子节点，折叠时隐藏子节点
        if (isExpanded) {
          html += '<div style="padding-left:24px;margin-top:8px;border-left:2px solid var(--border);">' + renderConfigSection(item.children, itemPath) + '</div>';
        }
      } else {
        html += '<div style="font-weight:500;display:flex;align-items:center;gap:8px;">';
        html += '<span style="font-size:12px;color:var(--text-muted);">' + icon + '</span>';
        html += '<span style="color:var(--primary);">' + key + '</span>';
        html += '<span style="font-size:11px;background:' + typeColor + ';color:white;padding:2px 6px;border-radius:4px;">' + item.type + '</span>';
        html += '</div>';
        html += '<div style="font-size:13px;color:var(--text-muted);padding-left:24px;margin-top:4px;">' + item.desc + '</div>';
      }
      html += '</div>';
    }
    return html;
  }

  /**
   * 切换配置区域展开状态
   *
   * @param path - 配置路径
   * @author lvdaxianerplus
   * @date 2026-04-20
   */
  function toggleConfigSection(path) {
    // 条件注释：展开时切换为折叠，折叠时切换为展开
    if (configSectionsExpanded[path]) {
      configSectionsExpanded[path] = false;
    } else {
      configSectionsExpanded[path] = true;
    }
    renderConfigReference();
  }

  /**
   * 切换所有配置区域的展开/折叠状态
   *
   * @author lvdaxianerplus
   * @date 2026-04-20
   */
  function toggleAllConfigSections() {
    // 条件注释：检查是否有展开的区域
    const hasExpanded = Object.keys(configSectionsExpanded).some(k => configSectionsExpanded[k]);
    // 条件注释：有展开区域时全部折叠，无展开区域时全部展开
    if (hasExpanded) {
      configSectionsExpanded = {};
    } else {
      // 遍历所有配置路径，设置为展开
      function collectPaths(section, path) {
        for (const key in section) {
          const item = section[key];
          const itemPath = path + '.' + key;
          // 条件注释：有子节点时设置为展开状态
          if (item.children && Object.keys(item.children).length > 0) {
            configSectionsExpanded[itemPath] = true;
            collectPaths(item.children, itemPath);
          }
        }
      }
      collectPaths(CONFIG_REFERENCE, 'config');
    }
    renderConfigReference();
  }

  // 初始化配置说明面板
  renderConfigReference();
</script>