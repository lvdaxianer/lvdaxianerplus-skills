<!-- Tools Page - 工具管理页面 -->
<div id="page-tools" class="page">
  <div class="bento-grid">
    <!-- Global Mock -->
    <div class="card span-12">
      <div class="card-title">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        全局 Mock 控制
      </div>
      <button id="global-mock-toggle" class="btn btn-secondary">加载中...</button>
    </div>

    <!-- Fallback Conditions Template - 降级条件模板配置 -->
    <div class="card span-12">
      <div class="card-title">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.542 0 2.465-1.333 1.938-2.667l-4.327-10.666c-.528-1.334-1.946-1.334-2.473 0L7.06 16.333C6.533 17.667 7.456 19 8.998 19z"/></svg>
        降级条件模板（返回值判断降级）
        <button class="btn btn-sm btn-secondary" style="margin-left:8px;" onclick="loadFallbackConditions()">刷新</button>
      </div>
      <div style="margin-bottom:12px;">
        <label style="display:flex;align-items:center;gap:8px;">
          <input type="checkbox" id="fallback-conditions-enabled" onchange="toggleFallbackConditions()">
          <span>启用返回值降级判断</span>
        </label>
      </div>
      <div style="margin-bottom:12px;font-size:13px;color:var(--text-muted);">
        <p>配置降级条件后，即使 HTTP 状态码正常（2xx），如果响应数据满足条件也会触发降级链。</p>
        <p>示例条件：<code>$.data == false</code> 或 <code>$.code != 200</code> 或 <code>$.data.length == 0</code></p>
      </div>
      <div id="fallback-conditions-list" style="max-height:200px;overflow-y:auto;margin-bottom:12px;">
        <!-- 条件列表由 JS 动态渲染 -->
      </div>
      <div style="display:flex;gap:8px;">
        <button class="btn btn-secondary" onclick="addFallbackCondition()">+ 添加条件</button>
        <button class="btn btn-primary" onclick="saveFallbackConditions()">保存配置</button>
      </div>
    </div>

    <!-- Tools List -->
    <div class="card span-12">
      <div class="card-title">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        工具列表
      </div>
      <div class="table-wrapper">
        <table>
          <thead><tr><th>名称</th><th>方法</th><th>路径</th><th>缓存</th><th>Mock</th><th>操作</th></tr></thead>
          <tbody id="tools-body">
            <tr><td colspan="6" style="text-align: center; color: var(--text-muted);">加载中...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>