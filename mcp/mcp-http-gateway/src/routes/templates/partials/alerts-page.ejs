<!-- Alerts Page - 告警管理页面 -->
<div id="page-alerts" class="page">
  <div class="bento-grid">
    <div class="card span-12">
      <div class="card-title">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        告警管理
      </div>
      <div class="form-row" style="margin-bottom: 16px;">
        <div class="form-group">
          <label class="form-label">严重级别</label>
          <select id="alert-severity-filter" class="form-input">
            <option value="">全部</option>
            <option value="critical">Critical</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">解决状态</label>
          <select id="alert-resolved-filter" class="form-input">
            <option value="">全部</option>
            <option value="false">未解决</option>
            <option value="true">已解决</option>
          </select>
        </div>
        <div class="form-group" style="flex: 0 0 auto;">
          <label class="form-label">&nbsp;</label>
          <button class="btn btn-primary" onclick="loadAlerts()">查询</button>
          <button class="btn btn-danger" onclick="resolveAllAlerts()" style="margin-left: 8px;">批量解决</button>
        </div>
      </div>
      <div class="table-wrapper">
        <table>
          <thead><tr><th>时间</th><th>类型</th><th>级别</th><th>工具</th><th>消息</th><th>状态</th><th>操作</th></tr></thead>
          <tbody id="alerts-table-body">
            <tr><td colspan="7" style="text-align:center;color:var(--text-muted);">加载中...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>