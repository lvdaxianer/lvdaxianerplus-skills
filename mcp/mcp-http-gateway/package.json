{
  "name": "@lvdaxianer/mcp-http-gateway",
  "version": "1.0.5",
  "description": "MCP HTTP Gateway - 将 LLM 工具调用转发到 HTTP REST API，支持熔断器、降级策略、缓存、Mock、SQLite 日志。版本策略：偶数版本（如 1.0、1.2）为稳定版，奇数版本（如 1.1、1.3）为快速迭代版。",
  "author": {
    "name": "lvdaxianer",
    "email": "lvdaxianer.plus@foxmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/lvdaxianer/lvdaxianerplus-ai/tree/main/mcp/mcp-http-gateway",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lvdaxianer/lvdaxianerplus-ai.git",
    "directory": "mcp/mcp-http-gateway"
  },
  "bugs": {
    "url": "https://github.com/lvdaxianer/lvdaxianerplus-ai/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "http-gateway",
    "llm",
    "claude",
    "anthropic",
    "circuit-breaker",
    "fallback",
    "cache",
    "mock",
    "sqlite",
    "dashboard"
  ],
  "bin": {
    "mcp-http-gateway": "dist/cli.cjs"
  },
  "files": [
    "dist/cli.cjs",
    "dist/templates",
    "docs",
    "README.md",
    "README_CN.md",
    "LICENSE",
    "CHANGELOG.md",
    "CHANGELOG_EN.md",
    "CONFIG.md",
    "CONFIG_EN.md",
    "NPM_PUBLISH_CHECKLIST.md"
  ],
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/cli.cjs --external:better-sqlite3 --banner:js='#!/usr/bin/env node' --minify && cp -r src/routes/templates dist/templates",
    "start": "node dist/cli.cjs",
    "dev": "npm run build && node dist/cli.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "ejs": "^5.0.2",
    "https-proxy-agent": "^7.0.0",
    "lru-cache": "^10.0.0",
    "prom-client": "^15.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/ejs": "^3.1.5",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
